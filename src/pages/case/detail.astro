---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import PillCtaLink from "../../components/PillCtaLink.astro";
import { withBase } from "../../utils/withBase";

const base = "/img/case";
const heroSrc = `${base}/img_dummy_lg.png`;

const specLeft = [
  {
    label: "所在地",
    value: "滋賀県XX市",
  },
  { label: "建築面積", value: "146.10m²" },
  { label: "構造", value: "木造" },
  { label: "用途", value: "アパート・マンション" },
  { label: "区画", value: "2LDK×8戸" },
] as const;

const specRight = [
  { label: "敷地面積", value: "209.88m2" },
  { label: "延床面積", value: "747.53m²" },
  { label: "規模", value: "地上2階" },
  { label: "戸数", value: "8" },
  { label: "竣工", value: "2024年9月" },
] as const;

const galleryImages = Array.from({ length: 9 }, (_, i) => ({
  src: `${base}/img_dummy.png`,
  alt: "",
}));

const relatedCases = [
  {
    title: "滋賀県XX市・商品名（見出し）",
    tags: ["タグ", "タグ", "タグ"],
  },
  {
    title: "滋賀県XX市・商品名（見出し）",
    tags: ["タグ", "タグ"],
  },
  {
    title: "滋賀県XX市・商品名（見出し）",
    tags: ["タグ", "タグ", "タグ"],
  },
] as const;
---

<Layout title="施工事例詳細" description="施工事例の詳細ページ。">
  <PageHero imageSrc="/img/case/img_header.png" imageAlt="" title="施工事例" />
  <Breadcrumbs
    items={[
      { label: "TOP", href: "/" },
      { label: "施工事例", href: "/case" },
      { label: "滋賀県XX市・商品名（見出し）" },
    ]}
  />
  <section class="case-detail section">
    <div class="section__inner case-detail__inner">
      <article class="case-detail__article">
        <header class="case-detail__header">
          <h1 class="case-detail__title">滋賀県XX市・商品名（見出し）</h1>
          <p class="case-detail__badge">アパート・マンション</p>
          <ul class="case-detail__tags">
            <li><span class="case-detail__tag">タグ</span></li>
            <li><span class="case-detail__tag">タグ</span></li>
            <li><span class="case-detail__tag">タグ</span></li>
          </ul>
        </header>

        <figure class="case-detail__kv">
          <img
            src={withBase(heroSrc)}
            alt=""
            width="1200"
            height="675"
            loading="eager"
          />
        </figure>

        <div class="case-detail__spec" aria-label="物件概要">
          <div class="case-detail__spec-side">
            <dl class="case-detail__spec-col">
              {
                specLeft.map((row) => (
                  <div
                    class:list={[
                      "case-detail__spec-row",
                      row.invert && "case-detail__spec-row--invert",
                    ]}
                  >
                    <dt>{row.label}</dt>
                    <dd>{row.value}</dd>
                  </div>
                ))
              }
            </dl>
          </div>
          <div class="case-detail__spec-side">
            <dl class="case-detail__spec-col">
              {
                specRight.map((row) => (
                  <div class="case-detail__spec-row">
                    <dt>{row.label}</dt>
                    <dd>{row.value}</dd>
                  </div>
                ))
              }
            </dl>
          </div>
        </div>

        <ul class="case-detail__gallery">
          {
            galleryImages.map((g) => (
              <li class="case-detail__gallery-item">
                <img
                  src={withBase(g.src)}
                  alt={g.alt}
                  width="400"
                  height="260"
                  loading="lazy"
                />
              </li>
            ))
          }
        </ul>

        <div class="case-detail__back">
          <PillCtaLink
            href={withBase("/case")}
            label="施工事例一覧へ戻る"
            width="base"
          />
        </div>
      </article>

      <section
        class="case-detail__related"
        aria-labelledby="case-related-heading"
      >
        <h2 class="case-detail__related-heading" id="case-related-heading">
          同じ種類の施工事例
        </h2>
        <div class="top-case case-detail__related-cards">
          <ul class="top-case__grid">
            {
              relatedCases.map((item) => (
                <li class="top-case__item">
                  <span class="top-case__badge">アパート・マンション</span>
                  <a href={withBase("/case/detail")} class="top-case__card">
                    <div class="top-case__media">
                      <img
                        src={withBase(`${base}/img_dummy.png`)}
                        alt=""
                        width="400"
                        height="300"
                        loading="lazy"
                      />
                    </div>
                    <div class="top-case__body">
                      <p class="top-case__name">{item.title}</p>
                      <ul class="top-case__tags">
                        {item.tags.map((t) => (
                          <li>
                            <span class="top-case__tag">{t}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </section>
    </div>
  </section>
</Layout>

<style lang="scss" is:global>
  @use "sass:color";
  @use "../../styles/variables" as *;
  @use "../../styles/case-study-cards";

  .case-detail {
    background: $color-white;

    .case-detail__inner {
      max-width: $content-max-width;
      margin: 0 auto;

      @media (max-width: $breakpoint-sp) {
        padding: $spacing-xl 0;
      }
    }

    .case-detail__article {
      margin: 0 0 $spacing-xxl;

      @media (max-width: $breakpoint-sp) {
        margin-bottom: $spacing-xl;
      }
    }

    .case-detail__header {
      margin: 0 0 $spacing-lg;
    }

    .case-detail__title {
      margin: 0 0 $spacing-sm;
      font-size: 28px;
      font-weight: $fw-bold;
      line-height: 1.45;
      color: $color-text;

      @media (max-width: $breakpoint-sp) {
        font-size: 22px;
      }
    }

    .case-detail__badge {
      display: inline-block;
      margin: 0 0 $spacing-sm;
      padding: 8px 14px;
      font-size: 12px;
      font-weight: $fw-bold;
      line-height: 1.35;
      color: $color-white;
      background:
        repeating-linear-gradient(
          -36deg,
          rgba($color-white, 0.14) 0,
          rgba($color-white, 0.14) 1px,
          transparent 1px,
          transparent 5px
        ),
        $color-primary;
    }

    .case-detail__tags {
      display: flex;
      flex-wrap: wrap;
      gap: $spacing-xs;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .case-detail__tag {
      display: inline-block;
      padding: 7px 14px;
      font-size: 14px;
      font-weight: $fw-medium;
      line-height: 1.3;
      color: $color-primary;
      background: $color-secondary;
      border: 1px dashed $color-primary;
      border-radius: 999px;
    }

    .case-detail__kv {
      margin: 0 0 $spacing-xl;
      padding: 0;

      img {
        display: block;
        width: 100%;
        height: auto;
        border-radius: 0;
      }

      @media (max-width: $breakpoint-sp) {
        margin-bottom: $spacing-lg;
      }
    }

    .case-detail__spec {
      display: grid;
      grid-template-columns: 1fr 1fr;
      margin: 0 0 $spacing-xl;
      padding: 0;
      background: $color-white;
      border: 1px solid #{color.mix($color-white, $color-text, 82%)};
      width: 85%;

      @media (max-width: $breakpoint-sp) {
        grid-template-columns: 1fr;
        margin-bottom: $spacing-lg;
      }
    }

    .case-detail__spec-side {
      min-width: 0;
      border-right: 1px solid #{color.mix($color-white, $color-text, 82%)};

      &:last-child {
        border-right: none;
      }

      @media (max-width: $breakpoint-sp) {
        border-right: none;
        border-bottom: 1px solid #{color.mix($color-white, $color-text, 82%)};

        &:last-child {
          border-bottom: none;
        }
      }
    }

    .case-detail__spec-head {
      min-height: 44px;
      background: $color-secondary;
      @media (max-width: $breakpoint-sp) {
        min-height: 36px;
      }
    }

    .case-detail__spec-col {
      margin: 0;
      padding: 0;
    }

    .case-detail__spec-row {
      display: grid;
      grid-template-columns: minmax(112px, 38%) 1fr;
      align-items: stretch;
      margin: 0;
      border-bottom: 1px solid #{color.mix($color-white, $color-text, 82%)};

      &:last-child {
        border-bottom: none;
      }

      @media (max-width: $breakpoint-sp) {
        grid-template-columns: minmax(100px, 36%) 1fr;
      }

      dt {
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0;
        padding: $spacing-sm $spacing-xs;
        font-size: 14px;
        font-weight: $fw-bold;
        line-height: 1.45;
        color: $color-text;
        text-align: center;
        background: $color-secondary;
        border-right: 1px solid #{color.mix($color-white, $color-text, 82%)};

        @media (max-width: $breakpoint-sp) {
          font-size: 13px;
          padding: $spacing-xs;
        }
      }

      dd {
        display: flex;
        align-items: center;
        margin: 0;
        padding: $spacing-sm $spacing-md;
        font-size: 15px;
        font-weight: $fw-regular;
        line-height: 1.6;
        color: $color-text;
        text-align: left;
        background: $color-white;

        @media (max-width: $breakpoint-sp) {
          font-size: 14px;
          padding: $spacing-sm;
        }
      }

      &.case-detail__spec-row--invert {
        dd {
          color: $color-white;
        }
      }
    }

    .case-detail__gallery {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin: 0 0 $spacing-xl;
      padding: 1px;
      list-style: none;

      @media (max-width: $breakpoint-sp) {
        margin-bottom: $spacing-lg;
      }
    }

    .case-detail__gallery-item {
      margin: 0;
      background: $color-white;

      img {
        display: block;
        width: 100%;
        height: auto;
        vertical-align: middle;
      }
    }

    .case-detail__back {
      display: flex;
      justify-content: center;
      margin: 0;
    }

    .case-detail__related {
      margin: 0;
      padding: 0;
    }

    .case-detail__related-heading {
      margin: 0 0 $spacing-lg;
      padding: 0;
      font-size: 28px;
      font-weight: $fw-bold;
      line-height: 1.45;
      color: $color-text;
      text-align: left;

      &::after {
        content: "";
        display: block;
        width: 50px;
        height: 5px;
        margin-top: $spacing-sm;
        background: $color-primary;
      }

      @media (max-width: $breakpoint-sp) {
        font-size: 28px;
        margin-bottom: $spacing-md;
      }
    }

    .case-detail__related-cards {
      margin: 0;
    }
  }
</style>
