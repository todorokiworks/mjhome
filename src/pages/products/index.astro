---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { productLineup } from "../../data/productLineup";
import { withBase } from "../../utils/withBase";
---

<Layout title="商品一覧" description="MJ Homeの商品ブランド一覧。">
  <PageHero
    imageSrc="/img/product/img_header.png"
    imageAlt=""
    title="商品一覧"
  />
  <Breadcrumbs
    items={[
      { label: "TOP", href: "/" },
      { label: "商品一覧" },
    ]}
  />
  <section class="products-index section">
    <div class="section__inner">
      <SectionHeading
        titleJapanese="ブランドラインアップ"
        titleEnglish="Lineup"
        align="center"
      />
      <ul class="products-index__grid">
        {
          productLineup.map((product) => (
            <li class="products-index__item">
              <a href={withBase(product.href)} class="products-index__link">
                <img
                  src={withBase(product.src)}
                  alt={product.alt}
                  width="280"
                  height="120"
                  loading="lazy"
                />
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</Layout>

<style lang="scss">
  @use "../../styles/variables" as *;

  .products-index {
    .products-index__grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: $spacing-md;
      list-style: none;
      margin: 0;
      padding: 0;

      @media (max-width: $breakpoint-tb) {
        grid-template-columns: repeat(2, 1fr);
      }

      @media (max-width: $breakpoint-sp) {
        grid-template-columns: repeat(2, 1fr);
        gap: $spacing-sm;
      }
    }

    .products-index__link {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 120px;
      padding: $spacing-md;
      background: $color-white;
      border: 1px solid rgba($color-text, 0.08);
      border-radius: 4px;

      &:hover {
        opacity: 1;
        border-color: rgba($color-primary, 0.35);
      }

      img {
        max-width: 100%;
        max-height: 72px;
        width: auto;
        height: auto;
        object-fit: contain;
      }
    }
  }
</style>
