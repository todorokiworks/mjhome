---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import OtherProducts from "../../components/OtherProducts.astro";
import { withBase } from "../../utils/withBase";

const base = "/img/product/mezonage";
---

<Layout
  title="MEZONAGE"
  description="MEZONAGE — 流行に敏感な入居者を引き付けるメゾネット賃貸。株式会社エム・ジェイホーム。"
>
  <PageHero imageSrc={`${base}/img_header.png`} imageAlt="" title="MEZONAGE" />
  <Breadcrumbs
    items={[
      { label: "TOP", href: "/", useHomeIcon: true },
      { label: "商品一覧", href: "/products" },
      { label: "MEZONAGE" },
    ]}
  />

  <section class="products-intro" aria-labelledby="products-intro-heading">
    <p class="products-intro__bar" id="products-intro-heading">
      流行に敏感な<br class="sp" />入居者を引き付ける<br
        class="sp"
      />新しい賃貸アパート
    </p>
    <div class="products-intro__brand">
      <div class="products-intro__brand-inner">
        <img
          class="products-intro__mark"
          src={withBase(`${base}/img_logo.png`)}
          alt="MEZONAGE メゾネージ ロゴ"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <section class="products-main section">
    <div class="section__inner">
      <div class="intro">
        <div class="intro__image">
          <img
            src={withBase(`${base}/img_house01.png`)}
            alt=""
            loading="lazy"
          />
        </div>
        <div class="intro__text">
          <h2 class="intro__title">
            “古びるのではなく、<br class="sp" />価値を深める”賃貸 <br
            />ヨーロッパの街角のように、<br />
            リゾートのように
          </h2>
          <p class="intro__body">
            まるでヨーロッパの街並みのような、おしゃれで温かみのある外観。<br
            />明確なコンセプトをもとに設計されたメゾネット賃貸は、“ここでしか暮らせない”という特別感を演出します。<br
            />一般的な賃貸アパートとは一線を画すデザインで、<br
            />特定のライフスタイルや価値観を持つ層に強くアピール可能。<br
            />結果、差別化された物件として競争力を発揮します。
          </p>
        </div>
      </div>

      <div class="intro__gallery">
        <div class="intro__gallery-item">
          <img
            src={withBase(`${base}/img_house02.png`)}
            alt=""
            loading="lazy"
          />
        </div>
        <div class="intro__gallery-item">
          <img
            src={withBase(`${base}/img_house03.png`)}
            alt=""
            loading="lazy"
          />
        </div>
        <div class="intro__gallery-item">
          <img
            src={withBase(`${base}/img_house04.png`)}
            alt=""
            loading="lazy"
          />
        </div>
      </div>
    </div>

    <div class="section__inner">
      <article
        class="products-plan products-plan--1"
        aria-labelledby="mezonage-plan1-title"
      >
        <div class="products-plan__content">
          <div class="products-plan__text products-plan__text--r1">
            <h2 class="products-plan__title" id="mezonage-plan1-title">
              日差しに団欒も自在に愉しめる<br />リビングルーム
            </h2>
            <p class="products-plan__body">
              日本の住まい選びにおいて、日当りの良さは第一条件。<br />
              陽光溢れる2階リビングを実現する「メゾネージ」なら、数ある賃貸アパートの中でもひときわの明るさを誇ります。<br
              />
              洗練された空間でありながら、戸建住宅のように伸び伸び寛げるのもメリット。<br
              />
              他にはない贅沢な住まいとして、入居者の心を掴むに違いありません。
            </p>
          </div>
          <div class="products-plan__figure products-plan__figure--r1">
            <img
              src={withBase(`${base}/img_house05.png`)}
              alt="外観"
              width="800"
              height="520"
              loading="lazy"
            />
          </div>
        </div>

        <div class="products-plan__gallery products-plan__gallery--1">
          <div
            class="products-plan__gallery-col products-plan__gallery-col--left"
          >
            <figure
              class="products-plan__gallery-item products-plan__gallery-item--main"
            >
              <img
                src={withBase(`${base}/img_house06.png`)}
                alt="室内"
                width="640"
                height="520"
                loading="lazy"
              />
            </figure>
            <div class="products-plan__gallery-row">
              <figure class="products-plan__gallery-item">
                <img
                  src={withBase(`${base}/img_house08.png`)}
                  alt="居室"
                  width="320"
                  height="280"
                  loading="lazy"
                />
              </figure>
            </div>
          </div>
          <div
            class="products-plan__gallery-col products-plan__gallery-col--right"
          >
            <figure
              class="products-plan__gallery-item products-plan__gallery-item--main"
            >
              <img
                src={withBase(`${base}/img_house07.png`)}
                alt="リビング"
                width="640"
                height="520"
                loading="lazy"
              />
            </figure>
            <p class="products-plan__body">
              メゾネージは、建てた瞬間が完成ではなく、そこから“育っていく建築”です。<br
              />
              ヨーロッパの街並みに見られるような、経年によって美しさを増す佇まい。<br
              />時間が経つごとに風合いが深まり地域に溶け込み、街の景観を育てます。<br
              />
              不動産としての資産価値だけでなく、「残してよかった」と思える、資産を。
            </p>
            <figure class="products-plan__gallery-item">
              <img
                src={withBase(`${base}/img_house09.png`)}
                alt="水回り"
                width="320"
                height="280"
                loading="lazy"
              />
            </figure>
          </div>
        </div>
      </article>
    </div>
  </section>

  <OtherProducts />
</Layout>

<style lang="scss" is:global>
  @use "../../styles/variables" as *;
  @use "../../styles/products-plan-layout" as *;

  .products-main {
    .intro__title {
      font-size: 32px;
      font-weight: $fw-bold;
      margin-bottom: $spacing-md;
    }
  }
</style>
