---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import OtherProducts from "../../components/OtherProducts.astro";
import { withBase } from "../../utils/withBase";

const base = "/img/product/brickblock";
---

<Layout
  title="BRICK BLOCK"
  description="BRICK BLOCK — 戸建感覚の賃貸・投資用コンセプト住宅。株式会社エム・ジェイホーム。"
>
  <PageHero
    imageSrc={`${base}/img_header.png`}
    imageAlt=""
    title="BRICK BLOCK"
  />
  <Breadcrumbs
    items={[
      { label: "TOP", href: "/", useHomeIcon: true },
      { label: "商品一覧", href: "/products" },
      { label: "BRICK BLOCK" },
    ]}
  />

  <section class="products-intro" aria-labelledby="products-intro-heading">
    <p class="products-intro__bar" id="products-intro-heading">
      人気の「戸建てタイプ」<br class="sp" />長期入居率・高家賃設定
    </p>
    <div class="products-intro__brand">
      <div class="products-intro__brand-inner">
        <img
          class="products-intro__mark"
          src={withBase(`${base}/img_logo.png`)}
          alt="BRICK BLOCK"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <section class="products-main section">
    <div class="section__inner">
      <div class="intro">
        <div class="intro__image">
          <img
            src={withBase(`${base}/img_house01.png`)}
            alt=""
            loading="lazy"
          />
        </div>
        <div class="intro__text">
          <h2 class="intro__title">
            長期安定収入を生む、<br class="sp" />選ばれる“戸建て投資”
          </h2>
          <p class="intro__body">
            近年、賃貸経営ビジネスの中で新たなトレンドとして注目を集めているのが「戸建賃貸」です。<br
            />家族層やペット可物件を探している層からのニーズも高く、長期入居が見込める点や高めの家賃設定が可能な点も、オーナーにとって大きなメリットです。<br
            />住まいとしての快適さを重視する「借りたい人」にも、将来的な売却や資産価値を意識する「買いたい人」にも提案しやすく、投資・管理・運用のあらゆるフェーズにおいて高い汎用性を発揮する、非常に優れた賃貸スタイル。<br
            />
          </p>
        </div>
      </div>

      <div class="intro__gallery">
        <div class="intro__gallery-item">
          <img
            src={withBase(`${base}/img_house02.png`)}
            alt=""
            loading="lazy"
          />
        </div>
        <div class="intro__gallery-item">
          <img
            src={withBase(`${base}/img_house03.png`)}
            alt=""
            loading="lazy"
          />
        </div>
        <div class="intro__gallery-item">
          <img
            src={withBase(`${base}/img_house04.png`)}
            alt=""
            loading="lazy"
          />
        </div>
      </div>
    </div>

    <div class="section__inner">
      <article
        class="products-plan products-plan--1"
        aria-labelledby="brick-plan1-title"
      >
        <div class="products-plan__content">
          <div class="products-plan__text products-plan__text--r1">
            <h2 class="products-plan__title" id="brick-plan1-title">
              ロングスパンで活用できる、<br />充実のレイアウト
            </h2>
            <p class="products-plan__body">
              既存の住宅を施したスタイリッシュな外観と、快適な居住性を兼ね備えたコンセプト戸建住宅「BRICK
              BROCK」<br />
              ファミリー世帯から人気の高い戸建タイプにデザイン性をプラスすることで長期入居が見込める商品の実現。<br
              />
              1階のLDK<br />
              は、戸建賃貸ならではの広々空間が実現。2階にはxウォークローゼット付きの部屋などを配置。暮らしのメインステージであるLDKは広々空間。
              どこに居ても家族の存在を感じられる、開放感たっぷりのスペースを実現。
            </p>
          </div>
          <div class="products-plan__figure products-plan__figure--r1">
            <img
              src={withBase(`${base}/img_house05.png`)}
              alt="外観"
              width="800"
              height="520"
              loading="lazy"
            />
          </div>
        </div>

        <div class="products-plan__gallery products-plan__gallery--1">
          <div
            class="products-plan__gallery-col products-plan__gallery-col--left"
          >
            <figure
              class="products-plan__gallery-item products-plan__gallery-item--main"
            >
              <img
                src={withBase(`${base}/img_house06.png`)}
                alt="室内"
                width="640"
                height="520"
                loading="lazy"
              />
            </figure>
            <div class="products-plan__gallery-row">
              <figure class="products-plan__gallery-item">
                <img
                  src={withBase(`${base}/img_house08.png`)}
                  alt="居室"
                  width="320"
                  height="280"
                  loading="lazy"
                />
              </figure>
            </div>
          </div>
          <div
            class="products-plan__gallery-col products-plan__gallery-col--right"
          >
            <figure
              class="products-plan__gallery-item products-plan__gallery-item--main"
            >
              <img
                src={withBase(`${base}/img_house07.png`)}
                alt="リビング"
                width="640"
                height="520"
                loading="lazy"
              />
            </figure>
            <p class="products-plan__body">
              戸建てだから叶う、未来に備える不動産戦略。<br />
              相続も、万が一も、“出口”まで見据えた資産づくり。<br />
              今ある土地を、もっと“将来の安心”に変えられたら？戸建賃貸という選択は、<br
              />相続や資産の分割、万が一のときの出口戦略まで、柔軟に対応できる<br
              />次世代の資産活用術です。<br />
              1. 節税に強い、相続対策としての賃貸住宅<br />
              2. 売却しやすい、出口に強い資産<br />
              3. 家賃収入で“納税原資”にも
            </p>
            <figure class="products-plan__gallery-item">
              <img
                src={withBase(`${base}/img_house09.png`)}
                alt="水回り"
                width="320"
                height="280"
                loading="lazy"
              />
            </figure>
          </div>
        </div>
      </article>
    </div>
  </section>

  <OtherProducts />
</Layout>

<style lang="scss" is:global>
  @use "../../styles/variables" as *;
  @use "../../styles/products-plan-layout" as *;

  .products-main {
    .intro__title {
      font-size: 32px;
      font-weight: $fw-bold;
      margin-bottom: $spacing-md;
    }
  }
</style>
