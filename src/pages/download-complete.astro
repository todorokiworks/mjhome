---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import PillCtaLink from "../components/PillCtaLink.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { withBase } from "../utils/withBase";
---

<Layout
    title="資料ダウンロード完了"
    description="資料ダウンロードのお申し込みが完了しました。"
>
    <PageHero
        imageSrc="/img/company/img_header.png"
        imageAlt=""
        title="資料ダウンロード"
    />
    <Breadcrumbs
        items={[{ label: "TOP", href: "/" }, { label: "資料ダウンロード" }]}
    />
    <section class="complete-page section">
        <div class="section__inner complete-page__inner">
            <h1 class="complete-page__title">
                資料ダウンロードありがとうございます
            </h1>
            <div class="complete-page__body">
                <p>資料のダウンロードが完了しました。</p>
                <p>お申し込みいただき、誠にありがとうございます。</p>
                <p>
                    ご入力いただいたメールアドレス宛にも、資料ダウンロードURLを記載したメールをお送りしております。
                </p>
                <p>
                    万が一届いていない場合は、迷惑メールフォルダもあわせてご確認ください。
                </p>
                <p>ご不明点がございましたら、お気軽にお問い合わせください。</p>
            </div>
            <div class="complete-page__actions">
                <PillCtaLink
                    href={withBase("/")}
                    label="トップページへ"
                    width="base"
                />
            </div>
        </div>
    </section>
</Layout>

<style lang="scss" is:global>
    @use "../styles/variables" as *;

    .complete-page {
        background: $color-white;

        .complete-page__inner {
            max-width: $content-max-width;
            margin: 0 auto;
            padding: 0 $spacing-md $spacing-xxl;

            @media (max-width: $breakpoint-sp) {
                padding: 0 $spacing-sm $spacing-xxl;
            }
        }

        .complete-page__title {
            margin: 0 0 $spacing-lg;
            font-size: 28px;
            font-weight: $fw-bold;
            line-height: 1.45;
            color: $color-text;
            text-align: left;

            @media (max-width: $breakpoint-sp) {
                font-size: 22px;
                margin-bottom: $spacing-md;
            }
        }

        .complete-page__body {
            margin: 0 0 $spacing-xxl;
            font-size: 15px;
            font-weight: $fw-regular;
            line-height: 1.85;
            color: $color-text;
            text-align: left;

            p {
                margin: 0 0 1.1em;

                &:last-child {
                    margin-bottom: 0;
                }
            }

            @media (max-width: $breakpoint-sp) {
                margin-bottom: $spacing-xl;
                font-size: 14px;
            }
        }

        .complete-page__actions {
            display: flex;
            justify-content: center;
            margin: 0;
            padding: 0 0 $spacing-lg;

            @media (max-width: $breakpoint-sp) {
                padding-bottom: $spacing-md;
                width: 100%;

                :global(.pill-cta-link) {
                    width: 100%;
                    max-width: none;
                    box-sizing: border-box;
                }
            }
        }
    }
</style>
