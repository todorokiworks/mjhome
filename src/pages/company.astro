---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import SectionHeading from "../components/SectionHeading.astro";
import PillCtaLink from "../components/PillCtaLink.astro";
import { withBase } from "../utils/withBase";

const mapSearchUrl =
  "https://www.google.com/maps/search/?api=1&query=" +
  encodeURIComponent("〒526-0835 滋賀県長浜市室町109-1 16街区14番");
---

<Layout title="会社概要" description="株式会社エム・ジェイホームの会社概要。">
  <PageHero
    imageSrc="/img/company/img_header.png"
    imageAlt=""
    title="会社概要"
  />
  <Breadcrumbs items={[{ label: "TOP", href: "/" }, { label: "会社概要" }]} />
  <section class="company-page section">
    <div class="section__inner company-page__inner">
      <SectionHeading
        titleJapanese="会社概要"
        titleEnglish="Company"
        align="center"
      />
      <dl class="company-page__dl">
        <div class="company-page__row">
          <dt class="company-page__dt" aria-hidden="true">社名</dt>
          <dd class="company-page__dd">株式会社エム・ジェイホーム</dd>
        </div>
        <div class="company-page__row">
          <dt class="company-page__dt">本社所在地</dt>
          <dd class="company-page__dd">
            〒526-0835 <br class="sp" />滋賀県長浜市室町109-1 <br
              class="sp"
            />16街区14番
          </dd>
        </div>
        <div class="company-page__row">
          <dt class="company-page__dt">TEL／FAX</dt>
          <dd class="company-page__dd">
            TEL：0749-65-5940<br class="sp" />FAX：0749-65-5950
          </dd>
        </div>
        <div class="company-page__row">
          <dt class="company-page__dt">資本金</dt>
          <dd class="company-page__dd">66,000,000円</dd>
        </div>
        <div class="company-page__row">
          <dt class="company-page__dt">会社設立</dt>
          <dd class="company-page__dd">平成17年11月</dd>
        </div>
        <div class="company-page__row">
          <dt class="company-page__dt">従業員数</dt>
          <dd class="company-page__dd">111名 ※令和6年8月31日時点</dd>
        </div>
        <div class="company-page__row">
          <dt class="company-page__dt">代表者</dt>
          <dd class="company-page__dd">代表取締役社長 葛川 睦</dd>
        </div>
        <div class="company-page__row">
          <dt class="company-page__dt">事業内容</dt>
          <dd class="company-page__dd">
            賃貸仲介事業、賃貸管理事業、<br
              class="sp"
            />建築事業、不動産売買事業<br class="sp" />
            教育・子育て支援事業
          </dd>
        </div>
        <div class="company-page__row">
          <dt class="company-page__dt">登記所所在地</dt>
          <dd class="company-page__dd">
            〒526-0031 <br class="sp" />滋賀県長浜市八幡東町96-1
          </dd>
        </div>
        <div class="company-page__row">
          <dt class="company-page__dt" aria-hidden="true">免許</dt>
          <dd class="company-page__dd">
            <ul class="company-page__license-list">
              <li>宅地建物取引業者免許 国土交通大臣(1) 第10917号</li>
              <li>賃貸住宅管理業 国土交通大臣(1) 第1225号</li>
              <li>不動産特定共同事業 滋賀県知事登録(1) 第3号</li>
              <li>建設業許可 滋賀県知事許可 (特-5) 第61678号</li>
            </ul>
          </dd>
        </div>
      </dl>

      <SectionHeading
        titleJapanese="アクセス"
        titleEnglish="Access"
        align="center"
        headingLevel="h3"
      />
      <div class="company-page__access">
        <div class="company-page__access-visual">
          <img
            src={withBase("/img/company/img_access.png")}
            alt="株式会社エム・ジェイホーム 本社外観"
            width="1000"
            height="560"
            loading="lazy"
          />
        </div>
        <div class="company-page__access-body">
          <p class="company-page__access-title">
            株式会社エム・ジェイホーム 本社
          </p>
          <p class="company-page__access-address">
            〒526-0835 <br class="sp" />滋賀県長浜市室町109-1 16街区14番
          </p>
          <p class="company-page__access-tel">
            TEL：0749-65-5940 / FAX：0749-65-5950
          </p>
          <div class="company-page__access-cta">
            <PillCtaLink
              href={mapSearchUrl}
              label="Google mapで場所を確認する"
              width="base"
              trailingIcon="map"
            />
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style lang="scss" is:global>
  @use "sass:color";
  @use "../styles/variables" as *;

  .company-page {
    .company-page__inner {
      max-width: $content-max-width;
      margin: 0 auto;
      padding: 0 0 $spacing-xxl;
      background: $color-white;

      @media (max-width: $breakpoint-sp) {
        padding: 0 $spacing-sm $spacing-xxl;
      }
    }

    .company-page__dl {
      margin: 0 0 160px;

      @media (max-width: $breakpoint-sp) {
        margin-bottom: $spacing-xxl;
      }
    }

    .company-page__row {
      display: grid;
      grid-template-columns: minmax(140px, 220px) 1fr;
      gap: 0;
      padding: 0;
      align-items: stretch;
      border-bottom: 1px solid #{color.mix($color-white, $color-text, 82%)};
      border-left: 1px solid #{color.mix($color-white, $color-text, 82%)};
      border-right: 1px solid #{color.mix($color-white, $color-text, 82%)};

      @media (max-width: $breakpoint-sp) {
        grid-template-columns: minmax(96px, 32%) minmax(0, 1fr);
      }

      &:first-child {
        border-top: 1px solid #{color.mix($color-white, $color-text, 82%)};
      }
    }

    .company-page__dt {
      margin: 0;
      padding: $spacing-md $spacing-sm;
      font-size: 15px;
      font-weight: $fw-bold;
      line-height: 1.6;
      color: $color-text;
      text-align: left;
      background: $color-secondary;
      border-right: 1px solid #{color.mix($color-white, $color-text, 88%)};

      @media (max-width: $breakpoint-sp) {
        padding: $spacing-sm $spacing-sm;
        font-size: 13px;
        border-right: 1px solid #{color.mix($color-white, $color-text, 88%)};
      }

      &.company-page__dt--empty {
        @media (max-width: $breakpoint-sp) {
          min-width: 0;
        }
      }
    }

    .company-page__dd {
      margin: 0;
      padding: $spacing-md $spacing-md;
      font-size: 15px;
      font-weight: $fw-regular;
      line-height: 1.85;
      color: $color-text;
      background: $color-white;

      @media (max-width: $breakpoint-sp) {
        padding: $spacing-sm;
        font-size: 13px;
        line-height: 1.7;
        min-width: 0;
      }
    }

    .company-page__license-list {
      margin: 0;
      padding: 0;
      list-style: none;

      li {
        margin-bottom: $spacing-xs;

        &:last-child {
          margin-bottom: 0;
        }
      }
    }

    .company-page__access {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: $spacing-xl;
      align-items: start;
      margin-top: $spacing-lg;

      @media (max-width: $breakpoint-sp) {
        grid-template-columns: 1fr;
        gap: $spacing-md;
      }
    }

    .company-page__access-visual {
      margin: 0;

      img {
        display: block;
        width: 100%;
        height: auto;
        border-radius: 4px;
      }
    }

    .company-page__access-body {
      display: flex;
      flex-direction: column;
      gap: $spacing-sm;
      padding: 0;

      @media (max-width: $breakpoint-sp) {
        gap: $spacing-xs;
      }
    }

    .company-page__access-title {
      margin: 0;
      font-size: 20px;
      font-weight: $fw-bold;
      line-height: 1.5;
      color: $color-text;

      @media (max-width: $breakpoint-sp) {
      }
    }

    .company-page__access-address,
    .company-page__access-tel {
      margin: 0;
      font-size: 15px;
      font-weight: $fw-regular;
      line-height: 1.8;
      color: $color-text;

      @media (max-width: $breakpoint-sp) {
        font-size: 14px;
      }
    }

    .company-page__access-cta {
      margin-top: $spacing-md;
      display: flex;
      justify-content: flex-start;

      @media (max-width: $breakpoint-sp) {
        justify-content: center;
      }
    }
  }
</style>
