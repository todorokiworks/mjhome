---
import Layout from "../layouts/Layout.astro";
import PillCtaLink from "../components/PillCtaLink.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { productLineup } from "../data/productLineup";
import { withBase } from "../utils/withBase";
---

<Layout
  title="トップ"
  description="資産価値を守り、賃貸経営を強くする建築を。株式会社エム・ジェイホーム"
  disableSpHeaderOffset={true}
>
  <section class="top-mv">
    <div class="top-mv__image-wrap">
      <img
        class="top-mv__image"
        src={withBase("/img/top/img_mv.png")}
        alt=""
        width="1920"
        height="800"
      />
      <div class="top-mv__overlay" aria-hidden="true"></div>
    </div>
    <div class="top-mv__inner section__inner">
      <p class="top-mv__lead">
        <picture>
          <source
            srcset={withBase("/img/top/img_mv_lead-sp.png")}
            media="(max-width: 768px)"
          />
          <img
            src={withBase("/img/top/img_mv_lead.png")}
            alt="資産価値を守り、賃貸経営を強くする建築を。長期的な収益と建物維持を考えた、オーナー様視点の建築サービスをご提供します。"
          />
        </picture>
      </p>
    </div>
  </section>

  <section class="top-about section">
    <div class="section__inner">
      <div class="top-about__row">
        <div class="top-about__text">
          <SectionHeading
            titleJapanese="賃貸経営を支える、<br>頼れるパートナーとして"
            titleEnglish="reliable partner"
            textAlign="left"
          />
          <p class="top-about__paragraph">
            オーナー様の資産を守りながら、安定した賃貸経営を支えるため、定期的な巡回点検や清掃を行い快適な住環境を提供します。<br
            />
            空室対策として、ターゲット層に合わせたリノベーションや原状回復工事を提案し、早期入居を実現。<br
            />
            さらに、老朽化対策や漏水トラブルにも迅速に対応し、物件の価値を保ちます。<br
            />
            そして、エム・ジェイホームの強みとして、社内で新築アパートの施工管理を行っています。未活用の土地や投資家様のご要望に応じ、新築提案を行い、収益の高い物件を提供します。
          </p>
          <div class="top-about__cta">
            <PillCtaLink
              href={withBase("/beginner")}
              label="はじめての方へ"
              width="base"
            />
          </div>
        </div>
        <div class="top-about__media">
          <img
            src={withBase("/img/top/img_intro.png")}
            alt="現場で打ち合わせをする様子"
            width="560"
            height="420"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="top-products section">
    <div class="section__inner">
      <SectionHeading
        titleJapanese="商品一覧"
        titleEnglish="Products"
        align="center"
      />
    </div>
    <div class="top-products__band">
      <ul class="top-products__grid">
        {
          productLineup.map((product) => (
            <li class="top-products__item">
              <a href={withBase(product.href)} class="top-products__link">
                <img
                  src={withBase(product.src)}
                  alt={product.alt}
                  width="280"
                  height="120"
                  loading="lazy"
                />
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="top-case section">
    <div class="section__inner">
      <SectionHeading
        titleJapanese="施工事例"
        titleEnglish="Construction example"
        align="center"
      />
      <ul class="top-case__grid">
        <li class="top-case__item">
          <span class="top-case__badge">アパート・マンション</span>
          <a href={withBase("/case/detail")} class="top-case__card">
            <div class="top-case__media">
              <img
                src={withBase("/img/case/img_dummy.png")}
                alt="施工事例"
                width="400"
                height="260"
                loading="lazy"
              />
            </div>
            <div class="top-case__body">
              <p class="top-case__name">滋賀県XX市・商品名（見出し）</p>
              <ul class="top-case__tags">
                <li><span class="top-case__tag">タグ</span></li>
                <li><span class="top-case__tag">タグ</span></li>
                <li><span class="top-case__tag">タグ</span></li>
              </ul>
            </div>
          </a>
        </li>
        <li class="top-case__item">
          <span class="top-case__badge">アパート・マンション</span>
          <a href={withBase("/case/detail")} class="top-case__card">
            <div class="top-case__media">
              <img
                src={withBase("/img/case/img_dummy.png")}
                alt="施工事例"
                width="400"
                height="260"
                loading="lazy"
              />
            </div>
            <div class="top-case__body">
              <p class="top-case__name">K-smart 参考プラン</p>
              <ul class="top-case__tags">
                <li><span class="top-case__tag">タグ</span></li>
                <li><span class="top-case__tag">タグ</span></li>
              </ul>
            </div>
          </a>
        </li>
        <li class="top-case__item">
          <span class="top-case__badge">アパート・マンション</span>
          <a href={withBase("/case/detail")} class="top-case__card">
            <div class="top-case__media">
              <img
                src={withBase("/img/case/img_dummy.png")}
                alt="施工事例"
                width="400"
                height="260"
                loading="lazy"
              />
            </div>
            <div class="top-case__body">
              <p class="top-case__name">Plan 3</p>
              <ul class="top-case__tags">
                <li><span class="top-case__tag">タグ</span></li>
                <li><span class="top-case__tag">タグ</span></li>
                <li><span class="top-case__tag">タグ</span></li>
              </ul>
            </div>
          </a>
        </li>
        <li class="top-case__item">
          <span class="top-case__badge">アパート・マンション</span>
          <a href={withBase("/case/detail")} class="top-case__card">
            <div class="top-case__media">
              <img
                src={withBase("/img/case/img_dummy.png")}
                alt="施工事例"
                width="400"
                height="260"
                loading="lazy"
              />
            </div>
            <div class="top-case__body">
              <p class="top-case__name">滋賀県XX市・商品名（見出し）</p>
              <ul class="top-case__tags">
                <li><span class="top-case__tag">タグ</span></li>
                <li><span class="top-case__tag">タグ</span></li>
                <li><span class="top-case__tag">タグ</span></li>
              </ul>
            </div>
          </a>
        </li>
        <li class="top-case__item">
          <span class="top-case__badge">アパート・マンション</span>
          <a href={withBase("/case/detail")} class="top-case__card">
            <div class="top-case__media">
              <img
                src={withBase("/img/case/img_dummy.png")}
                alt="施工事例"
                width="400"
                height="260"
                loading="lazy"
              />
            </div>
            <div class="top-case__body">
              <p class="top-case__name">K-smart 参考プラン</p>
              <ul class="top-case__tags">
                <li><span class="top-case__tag">タグ</span></li>
                <li><span class="top-case__tag">タグ</span></li>
              </ul>
            </div>
          </a>
        </li>
        <li class="top-case__item">
          <span class="top-case__badge">アパート・マンション</span>
          <a href={withBase("/case/detail")} class="top-case__card">
            <div class="top-case__media">
              <img
                src={withBase("/img/case/img_dummy.png")}
                alt="施工事例"
                width="400"
                height="260"
                loading="lazy"
              />
            </div>
            <div class="top-case__body">
              <p class="top-case__name">Plan 3</p>
              <ul class="top-case__tags">
                <li><span class="top-case__tag">タグ</span></li>
                <li><span class="top-case__tag">タグ</span></li>
                <li><span class="top-case__tag">タグ</span></li>
              </ul>
            </div>
          </a>
        </li>
      </ul>
      <div class="top-case__action">
        <PillCtaLink href={withBase("/case")} label="もっと見る" width="base" />
      </div>
    </div>
  </section>

  <section class="top-reason section">
    <div class="section__inner">
      <SectionHeading
        titleJapanese="選ばれる理由"
        titleEnglish="Why choose us"
        align="center"
      />
      <ul class="top-reason__list">
        <li class="top-reason__item">
          <span class="top-reason__num">01</span>
          <div class="top-reason__body">
            <h3 class="top-reason__title">低コスト実現</h3>
            <p class="top-reason__text">
              建物重量が軽く、基礎や地盤改良費まで抑えられるため、初期コストを軽減でき、無理のない賃貸経営をスタートできます。
            </p>
          </div>
        </li>
        <li class="top-reason__item">
          <span class="top-reason__num">02</span>
          <div class="top-reason__body">
            <h3 class="top-reason__title">短工期</h3>
            <p class="top-reason__text">
              資材調達がスムーズなため、鉄骨造に比べて工期短縮ができ、早期の収益化が可能です。
            </p>
          </div>
        </li>
        <li class="top-reason__item">
          <span class="top-reason__num">03</span>
          <div class="top-reason__body">
            <h3 class="top-reason__title">2×4工法</h3>
            <p class="top-reason__text">
              耐震性・耐火性に配慮しやすく、賃貸住宅の長期運用に適した木造工法です。
            </p>
          </div>
        </li>
      </ul>
      <div class="top-reason__action">
        <PillCtaLink
          href={withBase("/reason")}
          label="もっと見る"
          width="base"
        />
      </div>
    </div>
  </section>
</Layout>

<style lang="scss" is:global>
  @use "../styles/variables" as *;
  @use "../styles/case-study-cards";

  .top-mv {
    position: relative;
    margin-top: -100px;

    @media (max-width: $breakpoint-sp) {
      margin-top: -60px;
    }

    .top-mv__image-wrap {
      position: relative;
    }

    .top-mv__image {
      width: 100%;
      height: 850px;
      object-fit: cover;
      display: block;

      @media (max-width: $breakpoint-sp) {
        height: 600px;
      }
    }

    .top-mv__inner {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      z-index: 1;
      max-width: 1200px;
      width: 100%;
      padding: 0;

      @media (max-width: $breakpoint-sp) {
        padding-bottom: $spacing-xl;
        top: 55%;
        left: 50%;
        transform: translate(-50%, -40%);
      }
    }

    .top-mv__lead {
      max-width: 700px;
    }

    .top-mv__sub {
      font-family: $noto-sans-jp;
      font-size: 16px;
      color: $color-white;
      margin: 0;
      max-width: 520px;
      line-height: 1.75;

      @media (max-width: $breakpoint-sp) {
        font-size: 14px;
      }
    }
  }

  .top-about {
    @media (min-width: #{$breakpoint-sp + 1px}) {
      overflow-x: visible;
    }

    .top-about__row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: $spacing-xl;
      align-items: center;

      @media (min-width: #{$breakpoint-sp + 1px}) {
        overflow: visible;
      }

      @media (max-width: $breakpoint-sp) {
        grid-template-columns: 1fr;
      }
    }

    .top-about__paragraph {
      font-size: 15px;
      line-height: 1.9;
      margin: 0 0 $spacing-md;

      @media (max-width: $breakpoint-sp) {
        font-size: 14px;
      }
    }

    .top-about__cta {
      margin-top: $spacing-sm;
    }

    .top-about__media {
      @media (min-width: #{$breakpoint-sp + 1px}) {
        width: calc(
          100% +
            max(
              0px,
              (
                  min(100vw, #{$content-visual-max-width}) -
                    #{$content-max-width}
                ) /
                2
            )
        );
        margin-right: calc(
          -1 *
            max(
              0px,
              (
                  min(100vw, #{$content-visual-max-width}) -
                    #{$content-max-width}
                ) /
                2
            )
        );
      }

      img {
        width: 100%;
        height: auto;
        display: block;
      }
    }
  }

  .top-products {
    .top-products__band {
      width: 100%;
      max-width: $content-visual-max-width;
      margin-left: auto;
      margin-right: auto;
      box-sizing: border-box;
      padding-left: $spacing-md;
      padding-right: $spacing-md;

      @media (max-width: $breakpoint-sp) {
        padding-left: $spacing-sm;
        padding-right: $spacing-sm;
      }
    }

    .top-products__grid {
      display: grid;
      gap: $spacing-md;
      list-style: none;
      margin: 0;
      padding: 0;

      @media (min-width: #{$breakpoint-tb + 1px}) {
        grid-template-columns: repeat(12, 1fr);

        .top-products__item:nth-child(-n + 4) {
          grid-column: span 3;
        }

        .top-products__item:nth-child(n + 5) {
          grid-column: span 4;
        }
      }

      @media (max-width: $breakpoint-tb) {
        grid-template-columns: repeat(2, 1fr);

        .top-products__item {
          grid-column: auto;
        }
      }

      @media (max-width: $breakpoint-sp) {
        gap: $spacing-sm;
      }
    }

    .top-products__link {
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform 0.35s ease;

      &:hover {
        opacity: 0.9;
        transform: scale(1.02);
      }

      img {
        max-width: 100%;

        width: auto;
        height: auto;
        object-fit: contain;
      }
    }
  }

  .top-reason {
    .top-reason__list {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: $spacing-md;
      list-style: none;
      margin: 0;
      padding: $spacing-lg 0 0;
      overflow: visible;

      @media (max-width: $breakpoint-sp) {
        grid-template-columns: 1fr;
        gap: $spacing-lg;
        padding-top: $spacing-md;
      }
    }

    .top-reason__item {
      position: relative;
      overflow: visible;
      margin: 0;
      padding: 0;
      background: $color-white;
      box-shadow: 3px 3px 10px rgba($color-text, 0.2);
    }

    .top-reason__num {
      position: absolute;
      top: 0;
      left: 0;
      z-index: 1;
      font-family: $font-filmotype-lucky;
      font-size: 78px;
      font-style: italic;
      font-weight: $fw-regular;
      line-height: 0.85;
      color: $color-primary;
      pointer-events: none;
      transform: translate(-10%, -42%);

      @media (max-width: $breakpoint-sp) {
        font-size: 48px;
        left: $spacing-sm;
        transform: translate(-6%, -40%);
      }
    }

    .top-reason__body {
      padding: $spacing-xl $spacing-md $spacing-xl;

      @media (max-width: $breakpoint-sp) {
        padding: $spacing-lg $spacing-sm $spacing-sm;
      }
    }

    .top-reason__title {
      margin: 0 0 $spacing-sm;
      font-size: 28px;
      font-weight: $fw-bold;
      line-height: 1.45;
      color: $color-text;
      text-align: center;

      @media (max-width: $breakpoint-sp) {
        font-size: 18px;
      }
    }

    .top-reason__text {
      margin: 0;
      font-size: 16px;
      font-weight: $fw-regular;
      line-height: 2;
      color: $color-text;
      text-align: left;

      @media (max-width: $breakpoint-sp) {
        font-size: 13px;
        line-height: 1.7;
      }
    }

    .top-reason__action {
      text-align: center;
      margin-top: $spacing-xl;
      display: flex;
      justify-content: center;
    }

    .top-reason__button {
      display: inline-block;
      padding: 14px 40px;
      font-size: 15px;
      font-weight: $fw-medium;
      color: $color-white;
      background: $button-gradient;
      border-radius: 999px;
      text-decoration: none;

      &:hover {
        opacity: 0.9;
      }
    }
  }
</style>
