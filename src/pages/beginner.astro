---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { withBase } from "../utils/withBase";
---

<Layout title="はじめての方へ" description="MJ Homeが初めての方へ。">
  <PageHero
    imageSrc="/img/beginner/img_header.png"
    imageAlt=""
    title="はじめての方へ"
  />
  <Breadcrumbs
    items={[{ label: "TOP", href: "/" }, { label: "はじめての方へ" }]}
  />
  <section class="beginner section">
    <div class="section__inner">
      <section class="beginner__about">
        <div class="beginner__about-bleed">
          <div class="beginner__about-top">
            <div class="beginner__about-side beginner__about-side--left">
              <img
                src={withBase("/img/beginner/img_about01.png")}
                alt=""
                width="640"
                height="400"
                loading="lazy"
                decoding="async"
                class="beginner__about-img"
              />
            </div>
            <div class="beginner__about-main">
              <SectionHeading
                titleJapanese="About MJ Home"
                titleEnglish="About us"
                align="center"
              />
              <p class="beginner__lead">
                不動産のプロが考える、資産価値を高める<br />
                最適な建築・修繕・リノベーションをご提案します
              </p>
              <p class="beginner__body">
                エム・ジェイホームは、管理・仲介・売買部門と連携し、<br />
                資産価値を高めるための最適な建築・リフォーム・リノベーションをご提案できるのが当社の強み。<br
                />
                「空室が埋まらない」「収益が下がっている」「土地を有効活用したい」<br
                />そんなお悩みを、戦略的な建築プランで解決します。
              </p>
            </div>
            <div class="beginner__about-side beginner__about-side--right">
              <img
                src={withBase("/img/beginner/img_about02.png")}
                alt=""
                width="540"
                height="360"
                loading="lazy"
                decoding="async"
                class="beginner__about-img"
              />
            </div>
          </div>
          <div class="beginner__about-bottom">
            <div class="beginner__about-bottom-cell">
              <img
                src={withBase("/img/beginner/img_about03.png")}
                alt=""
                width="540"
                height="360"
                loading="lazy"
                decoding="async"
                class="beginner__about-img"
              />
            </div>
            <div class="beginner__about-bottom-cell">
              <img
                src={withBase("/img/beginner/img_about04.png")}
                alt=""
                width="640"
                height="400"
                loading="lazy"
                decoding="async"
                class="beginner__about-img"
              />
            </div>
          </div>
        </div>
      </section>
      <section class="beginner__strength">
        <SectionHeading
          titleJapanese="MJ Homeの強み"
          titleEnglish="Strengths"
          align="center"
        />
        <ul class="beginner__strengths">
          <li class="beginner__strength">
            <img
              src={withBase("/img/beginner/img_strength01.png")}
              alt=""
              width="400"
              height="240"
              loading="lazy"
            />
            <h3 class="beginner__strength-title">収益を最大化する建築プラン</h3>
            <p class="beginner__strength-text">
              市場ニーズや資産価値を考えた建築プランをご提案いたします。管理部門との連携で入居率を高め、仲介部門と協力して空室リスクを軽減。将来的にも価値が落ちにくい建物を実現します。
            </p>
          </li>
          <li class="beginner__strength">
            <img
              src={withBase("/img/beginner/img_strength02.png")}
              alt=""
              width="400"
              height="240"
              loading="lazy"
            />
            <h3 class="beginner__strength-title">
              コストを抑え品質を確保する施工
            </h3>
            <p class="beginner__strength-text">
              下請けを介さない「分離発注」＋「自社施工」を採用することで、余分なコストを削減。適正価格で資産価値を維持しながら、無駄のない修繕・リノベーションを提供します。
            </p>
          </li>
          <li class="beginner__strength">
            <img
              src={withBase("/img/beginner/img_strength03.png")}
              alt=""
              width="400"
              height="240"
              loading="lazy"
            />
            <h3 class="beginner__strength-title">管理×建築で資産価値アップ</h3>
            <p class="beginner__strength-text">
              長期的な運用を見据えた「管理目線の建築」を行っています。既存物件を家賃が下がりにくいリノベーションで収益化し、長期修繕計画を立てることで、将来の資産価値を維持します。
            </p>
          </li>
        </ul>
      </section>

      <section class="beginner__flow" aria-labelledby="beginner-flow-heading">
        <header class="beginner__flow-header">
          <p class="beginner__flow-deco" aria-hidden="true">Flow</p>
          <h2 class="beginner__flow-title" id="beginner-flow-heading">
            完成までの流れ
          </h2>
        </header>
        <ol class="beginner__flow-list">
          <li class="beginner__flow-item beginner__flow-item--1">
            <div class="beginner__flow-badge">
              <span class="beginner__flow-badge-label">STEP</span>
              <span class="beginner__flow-badge-num">1</span>
            </div>
            <h3 class="beginner__flow-item-title">
              お問い合わせ<br />相談・ヒアリング
            </h3>
            <p class="beginner__flow-item-body">
              まずはフォームより無料相談のお問い合わせをお願いいたします。こちらからご連絡、本事業のご説明・お持ちの土地を活用可能かどうか、投資金額の上限等のヒアリングを行います。
            </p>
          </li>
          <li class="beginner__flow-item beginner__flow-item--2">
            <div class="beginner__flow-badge">
              <span class="beginner__flow-badge-label">STEP</span>
              <span class="beginner__flow-badge-num">2</span>
            </div>
            <h3 class="beginner__flow-item-title">土地の調査</h3>
            <p class="beginner__flow-item-body">
              ヒアリングを行った後、土地の調査を行います。<br />
              お手元に測量図等がございましたらよりスムーズに進められるため可能であればご用意をお願いします。資料がない場合でも私たちで調査いたしますのでご安心ください。
            </p>
          </li>
          <li class="beginner__flow-item beginner__flow-item--3">
            <div class="beginner__flow-badge">
              <span class="beginner__flow-badge-label">STEP</span>
              <span class="beginner__flow-badge-num">3</span>
            </div>
            <h3 class="beginner__flow-item-title">市場調査</h3>
            <p class="beginner__flow-item-body">
              土地の現況が確認できたら、土地活用専門コンサルタントが周辺の家賃相場等を調査いたします。<br
              />
              2LDK等の家族向けにするのか、1Kの単身世帯向けにするのかの判断も合わせて行います。
            </p>
          </li>
          <li class="beginner__flow-item beginner__flow-item--4">
            <div class="beginner__flow-badge">
              <span class="beginner__flow-badge-label">STEP</span>
              <span class="beginner__flow-badge-num">4</span>
            </div>
            <h3 class="beginner__flow-item-title">事業計画・資金計画</h3>
            <p class="beginner__flow-item-body">
              調査した内容を踏まえ事業計画及び資金計画のご提案を行います。<br />
              オーナー様のご納得ができましたら融資相談を行います。弊社から金融機関をご紹介することも可能です。融資のご相談・事業計画のご説明についてもお任せいただけます。
            </p>
          </li>
          <li class="beginner__flow-item beginner__flow-item--5">
            <div class="beginner__flow-badge">
              <span class="beginner__flow-badge-label">STEP</span>
              <span class="beginner__flow-badge-num">5</span>
            </div>
            <h3 class="beginner__flow-item-title">契約・建築施工</h3>
            <p class="beginner__flow-item-body">
              オーナー様がご納得いただき、融資承認も下りたら建築契約になります。<br
              />
              賃貸マンションを建てる場合は、建築中から入居者の募集を行います。お付き合いのある管理会社がある場合にはその会社にご相談もしくは弊社からご紹介も可能です。
            </p>
          </li>
          <li class="beginner__flow-item beginner__flow-item--6">
            <div class="beginner__flow-badge">
              <span class="beginner__flow-badge-label">STEP</span>
              <span class="beginner__flow-badge-num">6</span>
            </div>
            <h3 class="beginner__flow-item-title">竣工・引き渡し</h3>
            <p class="beginner__flow-item-body">
              建物が無事完成したら、弊社で最終チェックを行いお引渡しになります。<br
              />
              建物の不具合等がございましたら何なりとご相談ください。
            </p>
          </li>
        </ol>
      </section>

      <section class="beginner__faq" aria-labelledby="beginner-faq-heading">
        <SectionHeading
          titleJapanese="よくある質問"
          titleEnglish="FAQ"
          align="center"
        />
        <div class="beginner__faq-list">
          <details class="beginner__faq-item">
            <summary class="beginner__faq-summary">
              <img
                class="beginner__faq-q-icon"
                src={withBase("/img/common/icon_q.png")}
                alt=""
                width="48"
                height="48"
                loading="lazy"
              />
              <span class="beginner__faq-question">
                賃貸経営って、本当に儲かるんでしょうか？
              </span>
              <span class="beginner__faq-chevron" aria-hidden="true"></span>
            </summary>
            <div class="beginner__faq-panel">
              <div class="beginner__faq-answer">
                <img
                  class="beginner__faq-a-icon"
                  src={withBase("/img/common/icon_a.png")}
                  alt=""
                  width="48"
                  height="48"
                  loading="lazy"
                />
                <div class="beginner__faq-answer-text">
                  <p>
                    賃貸経営は「必ず儲かる投資」ではありませんが、立地・建物・資金計画を正しく設計すれば、長期的に安定収益を得やすい投資です。特に木造建築は、
                  </p>
                  <p>
                    ・初期投資を抑えやすい<br />
                    ・減価償却のメリットが大きい
                  </p>
                  <p>
                    といった特徴があり、最初の一棟目として選ばれることが多い構造です。当社では、利回りだけでなく「空室リスク」「将来の修繕」「出口（売却）」まで含めてご提案しています。
                  </p>
                </div>
              </div>
            </div>
          </details>
          <details class="beginner__faq-item">
            <summary class="beginner__faq-summary">
              <img
                class="beginner__faq-q-icon"
                src={withBase("/img/common/icon_q.png")}
                alt=""
                width="48"
                height="48"
                loading="lazy"
              />
              <span class="beginner__faq-question">
                空室が続いたらどうなるのか不安です。
              </span>
              <span class="beginner__faq-chevron" aria-hidden="true"></span>
            </summary>
            <div class="beginner__faq-panel">
              <div class="beginner__faq-answer">
                <img
                  class="beginner__faq-a-icon"
                  src={withBase("/img/common/icon_a.png")}
                  alt=""
                  width="48"
                  height="48"
                  loading="lazy"
                />
                <div class="beginner__faq-answer-text">
                  <p>
                    空室リスクは、はじめてのオーナー様が最も不安に感じる点です。ただし、
                  </p>
                  <p>
                    ・入居ニーズのある立地選定<br />
                    ・ターゲットを明確にした間取り・設備<br />
                    ・管理会社との連携
                  </p>
                  <p>
                    これらを最初から設計に組み込むことで、空室リスクは大きく抑えることが可能です。「建ててから考える」のではなく、建てる前に“住む人”を想定することが重要です。
                  </p>
                </div>
              </div>
            </div>
          </details>
          <details class="beginner__faq-item">
            <summary class="beginner__faq-summary">
              <img
                class="beginner__faq-q-icon"
                src={withBase("/img/common/icon_q.png")}
                alt=""
                width="48"
                height="48"
                loading="lazy"
              />
              <span class="beginner__faq-question">
                木造は老朽化が早く、修繕費がかかりませんか？
              </span>
              <span class="beginner__faq-chevron" aria-hidden="true"></span>
            </summary>
            <div class="beginner__faq-panel">
              <div class="beginner__faq-answer">
                <img
                  class="beginner__faq-a-icon"
                  src={withBase("/img/common/icon_a.png")}
                  alt=""
                  width="48"
                  height="48"
                  loading="lazy"
                />
                <div class="beginner__faq-answer-text">
                  <p>
                    木造＝劣化が早い、というイメージを持たれがちですが、現在の木造建築は適切な施工とメンテナンスで十分長持ちします。また木造は、
                  </p>
                  <p>
                    ・修繕コストが比較的読みやすい<br />
                    ・大規模修繕の金額がRCより抑えやすい
                  </p>
                  <p>
                    というメリットもあります。当社では、将来の修繕を見据えた素材選定・構造設計を行っています。
                  </p>
                </div>
              </div>
            </div>
          </details>
          <details class="beginner__faq-item">
            <summary class="beginner__faq-summary">
              <img
                class="beginner__faq-q-icon"
                src={withBase("/img/common/icon_q.png")}
                alt=""
                width="48"
                height="48"
                loading="lazy"
              />
              <span class="beginner__faq-question">
                自己資金はいくらくらい必要ですか？
              </span>
              <span class="beginner__faq-chevron" aria-hidden="true"></span>
            </summary>
            <div class="beginner__faq-panel">
              <div class="beginner__faq-answer">
                <img
                  class="beginner__faq-a-icon"
                  src={withBase("/img/common/icon_a.png")}
                  alt=""
                  width="48"
                  height="48"
                  loading="lazy"
                />
                <div class="beginner__faq-answer-text">
                  <p>
                    物件規模や金融機関によって異なりますが、一般的には物件価格の1〜2割程度を想定される方が多いです。ただし、借入条件・返済期間・キャッシュフローによって最適な自己資金額は変わります。「できるだけ自己資金を抑えたい」「将来の余力を残したい」など、ご希望に応じた資金計画のご相談も可能です。
                  </p>
                </div>
              </div>
            </div>
          </details>
          <details class="beginner__faq-item">
            <summary class="beginner__faq-summary">
              <img
                class="beginner__faq-q-icon"
                src={withBase("/img/common/icon_q.png")}
                alt=""
                width="48"
                height="48"
                loading="lazy"
              />
              <span class="beginner__faq-question">
                賃貸経営の知識がなくても始められますか？
              </span>
              <span class="beginner__faq-chevron" aria-hidden="true"></span>
            </summary>
            <div class="beginner__faq-panel">
              <div class="beginner__faq-answer">
                <img
                  class="beginner__faq-a-icon"
                  src={withBase("/img/common/icon_a.png")}
                  alt=""
                  width="48"
                  height="48"
                  loading="lazy"
                />
                <div class="beginner__faq-answer-text">
                  <p>
                    はい、多くのオーナー様が未経験からスタートされています。重要なのは、「信頼できるパートナーを選ぶこと」「数字やリスクをきちんと説明してもらうこと」です。当社では、「専門用語を使わずに説明すること」「メリットだけでなくデメリットも正直に伝えること」を大切にしています。はじめての方でも、納得したうえで進められる体制を整えています。
                  </p>
                </div>
              </div>
            </div>
          </details>
        </div>
      </section>
    </div>
  </section>
</Layout>

<style lang="scss" is:global>
  @use "sass:color";
  @use "../styles/variables" as *;

  .beginner {
    .beginner__about {
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
      margin-bottom: 160px;
      padding-left: max(0, calc((100vw - #{$content-visual-max-width}) / 2));
      padding-right: max(0, calc((100vw - #{$content-visual-max-width}) / 2));
      box-sizing: border-box;

      @media (max-width: $breakpoint-sp) {
        margin-bottom: $spacing-xl;
      }

      .beginner__about-bleed {
        max-width: $content-visual-max-width;
        margin-left: auto;
        margin-right: auto;
      }

      .beginner__about-top {
        display: grid;
        grid-template-columns: 1fr minmax(0, 720px) 1fr;
        align-items: center;
        gap: $spacing-lg;
        margin-bottom: $spacing-xxl;

        @media (max-width: $breakpoint-sp) {
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: $spacing-sm;
          align-items: stretch;
          padding-top: 30px;
        }
      }

      .beginner__about-side {
        min-width: 0;

        @media (max-width: $breakpoint-sp) {
          width: 100%;
          max-width: none;
        }

        .beginner__about-img {
          width: 100%;
          height: auto;
          display: block;
        }
      }

      .beginner__about-main {
        min-width: 0;

        @media (max-width: $breakpoint-sp) {
          width: 100%;
          grid-column: 1 / -1;
          grid-row: 2;
        }

        .beginner__lead {
          margin-bottom: $spacing-lg;

          @media (max-width: $breakpoint-sp) {
            margin-bottom: $spacing-md;
          }
        }

        .beginner__body {
          margin-bottom: 0;
        }
      }

      .beginner__about-side--left {
        transform: translateY(-40px);
        @media (max-width: $breakpoint-sp) {
          transform: none;
          grid-column: 1;
          grid-row: 1;
        }
      }

      .beginner__about-side--right {
        transform: translateY(-120px);

        @media (max-width: $breakpoint-sp) {
          transform: translateY(-40px);
          grid-column: 2;
          grid-row: 1;
        }
      }

      .beginner__about-bottom {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: $spacing-xl;
        margin-top: $spacing-xl;
        max-width: 1200px;
        width: 100%;
        margin: 0 auto;

        @media (max-width: $breakpoint-sp) {
          grid-template-columns: 160px 1fr;
          gap: $spacing-sm;
          margin-top: $spacing-lg;
          width: 100%;
          max-width: none;
          margin-left: auto;
          margin-right: auto;
        }

        .beginner__about-bottom-cell {
          max-width: 510px;

          @media (max-width: $breakpoint-sp) {
            transform: none;
          }

          &:first-child {
            transform: translateX(-40px);

            @media (max-width: $breakpoint-sp) {
              transform: translateY(-20px) translateX(0px);
            }
          }

          &:last-child {
            transform: translate(40px, 60px);

            @media (max-width: $breakpoint-sp) {
              transform: none;
            }
          }

          .beginner__about-img {
            width: 100%;
            height: auto;
            display: block;
          }
        }
      }
    }

    .beginner__lead {
      text-align: center;
      font-size: 28px;
      font-weight: $fw-bold;
      line-height: 1.8;
      margin: 0 0 $spacing-xl;
      color: $color-primary;

      @media (max-width: $breakpoint-sp) {
        font-size: 16px;
      }
    }

    .beginner__body {
      line-height: 1.8;
      margin: 0 0 $spacing-xl;
      text-align: center;
    }

    .beginner__strengths {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: $spacing-lg;
      list-style: none;
      margin: 0;
      padding: 0;

      @media (max-width: $breakpoint-sp) {
        grid-template-columns: 1fr;
      }
    }

    .beginner__strength {
      img {
        width: 100%;
        height: auto;
        border-radius: 4px;
        margin-bottom: $spacing-sm;
      }
    }

    .beginner__strength-title {
      font-size: 28px;
      font-weight: $fw-bold;
      margin: 0 0 $spacing-xs;
      min-height: 100px;
    }

    .beginner__strength-text {
      line-height: 1.8;
      margin: 0;
    }

    .beginner__flow {
      position: relative;
      margin-top: $spacing-xxl;
      margin-bottom: $spacing-xxl;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
      padding: $spacing-xxl calc(50vw - 50%);
      background: color.mix($color-white, $color-text, 96%);

      @media (max-width: $breakpoint-sp) {
        margin-top: $spacing-xl;
        margin-bottom: $spacing-xl;
        padding: $spacing-xl calc(50vw - 50%);
      }
    }

    .beginner__flow-header {
      position: relative;
      margin: 0 0 $spacing-xl;
      padding: $spacing-lg 0 $spacing-md;
      text-align: center;

      @media (max-width: $breakpoint-sp) {
        margin-bottom: $spacing-lg;
        padding: $spacing-md 0;
      }
    }

    .beginner__flow-deco {
      position: absolute;
      left: 50%;
      top: 50%;
      z-index: 0;
      margin: 0;
      font-family: $font-filmotype-lucky;
      font-size: clamp(3.5rem, 12vw, 7.5rem);
      font-weight: $fw-regular;
      line-height: 1;
      color: $color-secondary;
      opacity: 0.95;
      pointer-events: none;
