---
import SectionHeading from "./SectionHeading.astro";
import type { ProductLogoItem } from "../types/product";
import { productLineup } from "../data/productLineup";
import { withBase } from "../utils/withBase";

interface Props {
  /** 未指定なら全ブランド一覧（現在ページも含む） */
  items?: ProductLogoItem[];
}

const { items = productLineup } = Astro.props;
---

<section class="other-products section">
  <div class="section__inner">
    <SectionHeading
      titleJapanese="他の商品を見る"
      titleEnglish="Other products"
      align="center"
    />
  </div>
  <div class="other-products__band">
    <ul class="other-products__grid">
      {
        items.map((item) => (
          <li class="other-products__item">
            <a href={withBase(item.href)} class="other-products__link">
              <img
                class="other-products__logo"
                src={withBase(item.src)}
                alt={item.alt}
                loading="lazy"
              />
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style lang="scss">
  @use "../styles/variables" as *;

  .other-products {
    .other-products__band {
      width: 100%;
      max-width: $content-visual-max-width;
      margin-left: auto;
      margin-right: auto;
      box-sizing: border-box;
      padding-left: $spacing-md;
      padding-right: $spacing-md;

      @media (max-width: $breakpoint-sp) {
        padding-left: $spacing-sm;
        padding-right: $spacing-sm;
      }
    }

    .other-products__grid {
      display: grid;
      gap: $spacing-md;
      list-style: none;
      margin: 0;
      padding: 0;

      @media (min-width: #{$breakpoint-tb + 1px}) {
        grid-template-columns: repeat(12, 1fr);

        .other-products__item:nth-child(-n + 4) {
          grid-column: span 3;
        }

        .other-products__item:nth-child(n + 5) {
          grid-column: span 4;
        }
      }

      @media (max-width: $breakpoint-tb) {
        grid-template-columns: repeat(2, 1fr);

        .other-products__item {
          grid-column: auto;
        }
      }

      @media (max-width: $breakpoint-sp) {
        gap: $spacing-sm;
      }
    }

    .other-products__item {
      margin: 0;
    }

    .other-products__link {
      display: flex;
      align-items: center;
      justify-content: center;
      transition:
        opacity 0.25s ease,
        transform 0.35s ease;

      &:hover {
        opacity: 0.9;
        transform: scale(1.02);
      }
    }

    .other-products__logo {
      max-width: 100%;

      width: auto;
      height: auto;
      object-fit: contain;
    }
  }
</style>
