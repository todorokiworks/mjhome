---

<header class="header">
  <div class="header__inner">
    <p class="header__logo">
      <a href="/">
        <img
          src="/img/common/img_logo.png"
          alt="MJ Home 株式会社エム・ジェイホーム"
          width="180"
          height="40"
        />
      </a>
    </p>
    <nav class="header__nav" aria-label="グローバルナビゲーション">
      <ul class="header__nav-list">
        <li class="header__nav-item">
          <a href="/" class="header__nav-link">トップ</a>
        </li>
        <li class="header__nav-item">
          <a href="/beginner" class="header__nav-link">はじめての方へ</a>
        </li>
        <li class="header__nav-item">
          <a href="/products" class="header__nav-link">商品一覧</a>
        </li>
        <li class="header__nav-item">
          <a href="/case" class="header__nav-link">施工事例</a>
        </li>
        <li class="header__nav-item">
          <a href="/reason" class="header__nav-link">選ばれる理由</a>
        </li>
        <li class="header__nav-item">
          <a href="/company" class="header__nav-link">会社概要</a>
        </li>
      </ul>
    </nav>
    <div class="header__button">
      <a href="/contact" class="header__contact-button">お問い合わせ</a>
    </div>
    <button
      class="header__menu-toggle"
      type="button"
      id="menuToggle"
      aria-label="メニューを開く"
      aria-expanded="false"
      aria-controls="menuOverlay"
    >
      <span class="header__menu-toggle-line"></span>
      <span class="header__menu-toggle-line"></span>
      <span class="header__menu-toggle-line"></span>
    </button>
  </div>
  <div
    class="header__menu-overlay"
    id="menuOverlay"
    role="dialog"
    aria-modal="true"
    aria-label="モバイルメニュー"
    hidden
  >
    <div class="header__menu-content">
      <div class="header__menu-header">
        <p class="header__menu-logo">
          <a href="/">
            <img
              src="/img/common/img_logo.png"
              alt="MJ Home"
              width="160"
              height="36"
            />
          </a>
        </p>
        <button
          class="header__menu-close"
          type="button"
          id="menuClose"
          aria-label="メニューを閉じる"
        >
          <span class="header__menu-close-icon" aria-hidden="true">×</span>
        </button>
      </div>
      <nav class="header__menu-nav" aria-label="モバイルナビゲーション">
        <ul class="header__menu-nav-list">
          <li class="header__menu-nav-item">
            <a href="/" class="header__menu-nav-link">トップ</a>
          </li>
          <li class="header__menu-nav-item">
            <a href="/beginner" class="header__menu-nav-link">はじめての方へ</a>
          </li>
          <li class="header__menu-nav-item">
            <a href="/products" class="header__menu-nav-link">商品一覧</a>
          </li>
          <li class="header__menu-nav-item">
            <a href="/case" class="header__menu-nav-link">施工事例</a>
          </li>
          <li class="header__menu-nav-item">
            <a href="/reason" class="header__menu-nav-link">選ばれる理由</a>
          </li>
          <li class="header__menu-nav-item">
            <a href="/company" class="header__menu-nav-link">会社概要</a>
          </li>
          <li class="header__menu-nav-item">
            <a href="/contact" class="header__menu-nav-link">お問い合わせ</a>
          </li>
        </ul>
      </nav>
      <div class="header__menu-button">
        <a href="/contact" class="header__contact-button header__contact-button--block"
          >お問い合わせ</a
        >
      </div>
    </div>
  </div>
</header>

<script>
  const menuToggle = document.getElementById("menuToggle");
  const menuClose = document.getElementById("menuClose");
  const menuOverlay = document.getElementById("menuOverlay");

  function openMenu() {
    menuOverlay?.removeAttribute("hidden");
    menuOverlay?.classList.add("header__menu-overlay--open");
    document.body.style.overflow = "hidden";
    menuToggle?.setAttribute("aria-expanded", "true");
  }

  function closeMenu() {
    menuOverlay?.classList.remove("header__menu-overlay--open");
    menuOverlay?.setAttribute("hidden", "");
    document.body.style.overflow = "";
    menuToggle?.setAttribute("aria-expanded", "false");
  }

  menuToggle?.addEventListener("click", () => {
    if (menuOverlay?.classList.contains("header__menu-overlay--open")) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  menuClose?.addEventListener("click", closeMenu);

  menuOverlay?.addEventListener("click", (e) => {
    if (e.target === menuOverlay) {
      closeMenu();
    }
  });
</script>

<style lang="scss" is:global>
  @use "../styles/variables" as *;

  .header {
    background-color: $color-white;
    position: fixed;
    width: 100%;
    left: 0;
    top: 0;
    z-index: 1000;
    border-bottom: 1px solid rgba($color-text, 0.08);

    .header__inner {
      max-width: $content-wrapper-width;
      margin: 0 auto;
      padding: 20px $spacing-md;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 30px;

      @media (max-width: $breakpoint-sp) {
        padding: 0 $spacing-sm;
        height: 60px;
      }
    }

    .header__logo {
      flex-shrink: 0;
      margin: 0;

      a {
        display: block;
        text-decoration: none;
      }

      img {
        height: 40px;
        width: auto;
        display: block;

        @media (max-width: $breakpoint-sp) {
          height: 30px;
        }
      }
    }

    .header__nav {
      flex: 1;
      display: flex;
      justify-content: flex-end;

      @media (max-width: $breakpoint-sp) {
        display: none;
      }

      .header__nav-list {
        display: flex;
        align-items: center;
        gap: $spacing-lg;
        list-style: none;
        margin: 0;
        padding: 0;
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      .header__nav-item {
        margin: 0;
      }

      .header__nav-link {
        color: $color-text;
        text-decoration: none;
        font-family: $noto-sans-jp;
        font-size: 15px;
        font-weight: $fw-medium;
        transition: opacity 0.3s ease;
        white-space: nowrap;

        &:hover {
          opacity: 0.7;
        }
      }
    }

    .header__button {
      flex-shrink: 0;

      @media (max-width: $breakpoint-sp) {
        display: none;
      }
    }

    .header__contact-button {
      display: inline-block;
      padding: 14px 28px;
      font-size: 15px;
      font-weight: $fw-medium;
      font-family: $noto-sans-jp;
      color: $color-white;
      text-decoration: none;
      border-radius: 999px;
      background: $button-gradient;
      border: none;
      cursor: pointer;
      transition: opacity 0.3s ease;
      text-align: center;

      &:hover {
        opacity: 0.9;
      }

      &.header__contact-button--block {
        width: 100%;
        display: block;
      }
    }

    .header__menu-toggle {
      display: none;
      flex-direction: column;
      justify-content: space-around;
      width: 24px;
      height: 24px;
      background: transparent;
      border: none;
      cursor: pointer;
      padding: 0;
      z-index: 1001;

      @media (max-width: $breakpoint-sp) {
        display: flex;
      }

      .header__menu-toggle-line {
        width: 100%;
        height: 2px;
        background-color: $color-text;
        border-radius: 2px;
        transition: all 0.3s ease;
      }
    }

    .header__menu-overlay {
      &[hidden] {
        display: none !important;
      }

      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100vh;
      z-index: 2000;
      background-color: rgba(0, 0, 0, 0.35);
      opacity: 0;
      visibility: hidden;
      transition:
        opacity 0.3s ease,
        visibility 0.3s ease;

      @media (max-width: $breakpoint-sp) {
        display: block;
      }

      &:not([hidden]).header__menu-overlay--open {
        opacity: 1;
        visibility: visible;
      }

      .header__menu-content {
        position: absolute;
        top: 0;
        right: 0;
        width: 100%;
        max-width: 360px;
        height: 100vh;
        background-color: $color-white;
        transform: translateX(100%);
        transition: transform 0.3s ease;
        display: flex;
        flex-direction: column;
        padding: 20px $spacing-sm;
        overflow-y: auto;
      }

      &.header__menu-overlay--open .header__menu-content {
        transform: translateX(0);
      }

      .header__menu-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-bottom: $spacing-md;
        border-bottom: 1px solid #e0e0e0;
      }

      .header__menu-logo {
        margin: 0;
        flex-shrink: 0;

        a {
          display: block;
        }

        img {
          height: 30px;
          width: auto;
          display: block;
        }
      }

      .header__menu-close {
        width: 32px;
        height: 32px;
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;

        .header__menu-close-icon {
          font-size: 32px;
          line-height: 1;
          color: $color-text;
          font-weight: 100;
        }
      }

      .header__menu-nav {
        margin-bottom: $spacing-sm;
        flex: 1;
      }

      .header__menu-nav-list {
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .header__menu-nav-item {
        margin: 0;
        border-bottom: 1px solid #e0e0e0;
      }

      .header__menu-nav-link {
        display: block;
        color: $color-text;
        text-decoration: none;
        font-family: $noto-sans-jp;
        font-size: 16px;
        font-weight: $fw-medium;
        padding: $spacing-sm 0;
        transition: opacity 0.3s ease;

        &:hover {
          opacity: 0.7;
        }
      }

      .header__menu-button {
        display: flex;
        justify-content: center;
        padding-top: $spacing-md;
      }
    }
  }
</style>
