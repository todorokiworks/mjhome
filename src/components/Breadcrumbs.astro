---
import type { BreadcrumbItem } from "../types/nav";
import { withBase } from "../utils/withBase";

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="breadcrumbs" aria-label="パンくずリスト">
  <ol class="breadcrumbs__list">
    {
      items.map((item, index) => (
        <li class="breadcrumbs__item">
          {item.href && index < items.length - 1 ? (
            <a
              href={withBase(item.href)}
              class:list={[
                "breadcrumbs__link",
                item.useHomeIcon && "breadcrumbs__link--home-icon",
              ]}
              aria-label={item.useHomeIcon ? "トップページへ" : undefined}
            >
              {item.useHomeIcon ? (
                <img
                  src={withBase("/img/common/icon_home.png")}
                  alt=""
                  width="20"
                  height="20"
                  loading="eager"
                />
              ) : (
                item.label
              )}
            </a>
          ) : (
            <span class="breadcrumbs__current">{item.label}</span>
          )}
          {index < items.length - 1 && (
            <span class="breadcrumbs__separator" aria-hidden="true">
              {" "}
              &gt;{" "}
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>

<style lang="scss" is:global>
  @use "../styles/variables" as *;

  .breadcrumbs {
    padding: $spacing-sm $spacing-md $spacing-lg;
    max-width: 1680px;
    margin: 0 auto;

    @media (max-width: $breakpoint-sp) {
      padding: $spacing-sm $spacing-sm $spacing-lg;
    }

    .breadcrumbs__list {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      list-style: none;
      margin: 0;
      padding: 0;
      font-family: $noto-sans-jp;
      font-size: 13px;
      color: #808080;
      @media (max-width: $breakpoint-sp) {
        font-size: 12px;
      }
    }

    .breadcrumbs__item {
      display: flex;
      align-items: center;
      margin: 0;
    }

    .breadcrumbs__link {
      color: rgba($color-text, 0.65);
      text-decoration: none;

      &:hover {
        color: $color-primary;
        opacity: 1;
      }

      &.breadcrumbs__link--home-icon {
        display: inline-flex;
        align-items: center;
        line-height: 1;

        img {
          display: block;
          width: 20px;
          height: 20px;
          object-fit: contain;
        }

        @media (max-width: $breakpoint-sp) {
          img {
            width: 18px;
            height: 18px;
          }
        }

        &:hover img {
          opacity: 0.75;
        }
      }
    }

    .breadcrumbs__current {
      color: #808080;
      font-weight: $fw-medium;
    }

    .breadcrumbs__separator {
      margin: 0 6px;
      color: rgba($color-text, 0.45);
    }
  }
</style>
