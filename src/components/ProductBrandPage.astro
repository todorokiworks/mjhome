---
import Layout from "../layouts/Layout.astro";
import PageHero from "./PageHero.astro";
import Breadcrumbs from "./Breadcrumbs.astro";
import ContentSplit from "./ContentSplit.astro";
import ImageGrid from "./ImageGrid.astro";
import OtherProducts from "./OtherProducts.astro";
import type { BreadcrumbItem } from "../types/nav";
import { otherProductsExcept } from "../data/productLineup";
import type { ProductSlug } from "../data/productLineup";

interface Props {
  title: string;
  description?: string;
  brandName: string;
  heroTitle: string;
  heroImage: string;
  breadcrumbs: BreadcrumbItem[];
  introLead?: string;
  introLogo?: string;
  introLogoAlt?: string;
  splits: {
    title: string;
    body: string;
    image: string;
    imageAlt: string;
    reverse?: boolean;
  }[];
  gallery: { src: string; alt: string }[];
  galleryColumns?: 2 | 3;
  excludeSlug: ProductSlug;
}

const {
  title,
  description,
  brandName,
  heroTitle,
  heroImage,
  breadcrumbs,
  introLead,
  introLogo,
  introLogoAlt = "",
  splits,
  gallery,
  galleryColumns = 3,
  excludeSlug,
} = Astro.props;

const otherItems = otherProductsExcept(excludeSlug);
---

<Layout title={title} description={description}>
  <PageHero imageSrc={heroImage} imageAlt="" title={heroTitle} />
  <Breadcrumbs items={breadcrumbs} />
  <section class="product-brand section">
    <div class="section__inner">
      {
        introLead && (
          <p class="product-brand__lead">{introLead}</p>
        )
      }
      {
        introLogo && (
          <div class="product-brand__logo-wrap">
            <img
              class="product-brand__logo"
              src={introLogo}
              alt={introLogoAlt || brandName}
              width="320"
              height="120"
              loading="lazy"
            />
          </div>
        )
      }
      {
        splits.map((split) => (
          <ContentSplit
            title={split.title}
            body={split.body}
            imageSrc={split.image}
            imageAlt={split.imageAlt}
            reverse={split.reverse}
          />
        ))
      }
      <ImageGrid images={gallery} columns={galleryColumns} />
    </div>
  </section>
  <OtherProducts items={otherItems} />
</Layout>

<style lang="scss">
  @use "../styles/variables" as *;

  .product-brand {
    .product-brand__lead {
      font-size: 18px;
      font-weight: $fw-bold;
      line-height: 1.8;
      text-align: center;
      margin: 0 0 $spacing-lg;

      @media (max-width: $breakpoint-sp) {
        font-size: 16px;
        margin-bottom: $spacing-md;
      }
    }

    .product-brand__logo-wrap {
      text-align: center;
      margin-bottom: $spacing-xl;

      @media (max-width: $breakpoint-sp) {
        margin-bottom: $spacing-lg;
      }
    }

    .product-brand__logo {
      max-width: 100%;
      height: auto;
    }
  }
</style>
