---
import { withBase } from "../utils/withBase";

interface Props {
  href: string;
  label: string;
  /** 親幅いっぱい（text と矢印を両端寄せ）／内容に合わせた幅 */
  width?: "full" | "base";
  class?: string;
}

const { href, label, width = "full", class: className } = Astro.props;

const iconSrc = withBase("/img/common/icon_arrow_white.png");
---

<a
  href={href}
  class:list={[
    "pill-cta-link",
    width === "full" && "pill-cta-link--full",
    width === "base" && "pill-cta-link--base",
    className,
  ]}
>
  <span class="pill-cta-link__label">{label}</span>
  <span class="pill-cta-link__icon" aria-hidden="true">
    <img src={iconSrc} alt="" width="20" height="12" loading="lazy" />
  </span>
</a>

<style lang="scss" is:global>
  @use "../styles/variables" as *;

  .pill-cta-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: $spacing-md;
    box-sizing: border-box;
    margin: 0;
    padding: 24px 28px;
    font-family: $noto-sans-jp;
    font-size: 16px;
    font-weight: $fw-bold;
    line-height: 1.3;
    color: $color-white;
    text-decoration: none;
    background: $color-primary;
    border-radius: 999px;
    transition: opacity 0.2s ease;
    width: 230px;

    &:hover {
      opacity: 0.9;
    }

    @media (max-width: $breakpoint-sp) {
      padding: 14px 22px;
      font-size: 14px;
    }

    &.pill-cta-link--full {
      width: 100%;
    }

    &.pill-cta-link--base {
      width: 230px;
    }

    .pill-cta-link__label {
      flex: 0 1 auto;
      text-align: left;
    }

    .pill-cta-link__icon {
      display: flex;
      flex-shrink: 0;
      align-items: center;
      justify-content: center;

      img {
        display: block;
        width: 12px;
        height: auto;

        @media (max-width: $breakpoint-sp) {
          width: 18px;
        }
      }
    }
  }
</style>
