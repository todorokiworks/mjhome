---
import SectionHeading from "./SectionHeading.astro";
import { withBase } from "../utils/withBase";

const bnrDl = withBase("/img/common/img_bnr_dl_bg.png");
const bnrContact = withBase("/img/common/img_bnr_contact_bg.png");
---

<footer class="footer">
  <div class="footer__cta-banners">
    <a
      href={withBase("/download")}
      class="footer__cta-banner footer__cta-banner--download"
      style={`background-image: url('${bnrDl}')`}
    >
      <SectionHeading
        titleJapanese="資料ダウンロード"
        titleEnglish="Download"
        headingLevel="h3"
        align="center"
        titleJapaneseColor="white"
      />
    </a>
    <a
      href={withBase("/contact")}
      class="footer__cta-banner footer__cta-banner--contact"
      style={`background-image: url('${bnrContact}')`}
    >
      <SectionHeading
        titleJapanese="お問い合わせ"
        titleEnglish="Contact"
        headingLevel="h3"
        align="center"
        titleJapaneseColor="white"
      />
    </a>
  </div>
  <div class="footer__main">
    <div class="footer__inner">
      <div class="footer__brand">
        <div class="footer__logo">
          <img
            src={withBase("/img/common/img_logo_footer.png")}
            alt="MJ Home"
            width="200"
            height="48"
          />
        </div>
        <div class="footer__company">
          <p class="footer__company-name">株式会社エム・ジェイホーム</p>
          <p class="footer__company-address">
            〒526-0835<br />
            滋賀県長浜市室町109-1 16街区14番
          </p>
          <p class="footer__company-contact">
            TEL:0749-65-5940 / FAX: 0749-65-5950
          </p>
        </div>
      </div>
      <nav class="footer__nav" aria-label="フッターナビゲーション">
        <ul class="footer__nav-list">
          <li class="footer__nav-item">
            <a href={withBase("/")} class="footer__nav-link">トップ</a>
          </li>
          <li class="footer__nav-item">
            <a href={withBase("/beginner")} class="footer__nav-link"
              >はじめての方へ</a
            >
          </li>
          <li class="footer__nav-item">
            <a href={withBase("/reason")} class="footer__nav-link"
              >選ばれる理由</a
            >
          </li>
        </ul>
        <ul class="footer__nav-list">
          <li class="footer__nav-item">
            <a href={withBase("/products")} class="footer__nav-link">商品一覧</a
            >
          </li>
          <li class="footer__nav-item">
            <a href={withBase("/case")} class="footer__nav-link">施工事例</a>
          </li>
          <li class="footer__nav-item">
            <a href={withBase("/company")} class="footer__nav-link">会社概要</a>
          </li>
        </ul>
      </nav>
      <div class="footer__actions">
        <a href={withBase("/contact")} class="footer__action-btn"
          >お問い合わせ</a
        >
        <a href={withBase("/download")} class="footer__action-btn"
          >資料ダウンロード</a
        >
      </div>
    </div>
  </div>
  <div class="footer__legal">
    <a href="#" class="footer__legal-link">プライバシーポリシー</a>
    <p class="footer__legal-copy">
      Copyright © 2025 MJ HOME Co., Ltd. All Rights Reserved.
    </p>
  </div>
</footer>

<style lang="scss" is:global>
  @use "../styles/variables" as *;

  .footer {
    background-color: $footer-background-color;
    color: $color-white;

    .footer__cta-banners {
      display: grid;
      grid-template-columns: 1fr 1fr;

      margin: 0 auto;

      @media (max-width: $breakpoint-sp) {
        grid-template-columns: 1fr;
      }
    }

    .footer__cta-banner {
      position: relative;
      min-height: 480px;
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      color: $color-white;
      background-size: cover;
      background-position: center;
      transition: opacity 0.3s ease;

      &::after {
        content: "";
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.01);
        transition: background 0.3s ease;
      }

      .section-heading {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: $content-max-width;
        margin-bottom: 0;
        padding-top: 0;

        @media (max-width: $breakpoint-sp) {
          margin-bottom: 0;
          padding-top: 0;
        }

        .section-heading__background {
          left: 50%;
          transform: translate(-50%, -50%);
          color: rgba($color-primary, 0.22);
        }

        .section-heading__title {
          padding-top: 0;

          @media (max-width: $breakpoint-sp) {
            padding-top: 0;
          }
        }
      }

      &:hover {
        opacity: 1;

        &::after {
          background: rgba(0, 0, 0, 0.55);
        }
      }
    }

    .footer__main {
      padding: $spacing-xxl $spacing-md 120px;

      @media (max-width: $breakpoint-sp) {
        padding: $spacing-xl $spacing-sm $spacing-lg;
      }
    }

    .footer__inner {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr) minmax(0, 240px);
      align-items: start;
      gap: $spacing-xl $spacing-xxl;
      box-sizing: border-box;
      max-width: $content-max-width;
      margin: 0 auto;

      @media (max-width: $breakpoint-tb) {
        grid-template-columns: 1fr 1fr;
        gap: $spacing-lg;

        .footer__actions {
          grid-column: 1 / -1;
          flex-direction: row;
          justify-content: flex-start;
        }

        .footer__action-btn {
          flex: 1 1 auto;
          max-width: 280px;
        }
      }

      @media (max-width: $breakpoint-sp) {
        grid-template-columns: 1fr;
        gap: $spacing-lg;

        .footer__actions {
          flex-direction: column;
        }

        .footer__action-btn {
          max-width: none;
        }
      }
    }

    .footer__brand {
      text-align: left;
    }

    .footer__logo {
      margin-bottom: $spacing-md;

      img {
        height: 48px;
        width: auto;
        display: block;

        @media (max-width: $breakpoint-sp) {
          height: 40px;
        }
      }
    }

    .footer__company {
      display: flex;
      flex-direction: column;
      gap: $spacing-xs;
      text-align: left;

      .footer__company-name {
        font-family: $noto-sans-jp;
        font-size: 18px;
        font-weight: $fw-bold;
        margin: 0;

        @media (max-width: $breakpoint-sp) {
          font-size: 16px;
        }
      }

      .footer__company-address {
        font-family: $noto-sans-jp;
        font-size: 15px;
        font-weight: $fw-regular;
        line-height: 1.8;
        margin: 0;

        @media (max-width: $breakpoint-sp) {
          font-size: 14px;
        }
      }

      .footer__company-contact {
        font-family: $noto-sans-jp;
        font-size: 15px;
        font-weight: $fw-regular;
        margin: 0;

        @media (max-width: $breakpoint-sp) {
          font-size: 14px;
        }
      }
    }

    .footer__nav {
      display: flex;
      flex-direction: row;
      flex-wrap: nowrap;
      justify-content: center;
      gap: $spacing-xl $spacing-xxl;

      @media (max-width: $breakpoint-sp) {
        justify-content: flex-start;
        gap: $spacing-lg;
      }

      .footer__nav-list {
        display: flex;
        flex-direction: column;
        gap: $spacing-sm;
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .footer__nav-item {
        margin: 0;
      }

      .footer__nav-link {
        color: $color-white;
        text-decoration: none;
        font-family: $noto-sans-jp;
        font-size: 15px;
        font-weight: $fw-medium;
        line-height: 1.5;
        transition: opacity 0.3s ease;

        &:hover {
          opacity: 0.7;
        }
      }
    }

    .footer__actions {
      display: flex;
      flex-direction: column;
      gap: $spacing-sm;
      align-items: stretch;
    }

    .footer__action-btn {
      display: block;
      box-sizing: border-box;
      padding: 24px $spacing-md;
      font-family: $noto-sans-jp;
      font-size: 15px;
      font-weight: $fw-medium;
      line-height: 1.4;
      color: $color-text;
      text-align: center;
      text-decoration: none;
      background: $color-white;
      border-radius: 999px;
      transition: opacity 0.25s ease;

      &:hover {
        opacity: 0.9;
      }
    }

    .footer__legal {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: $spacing-sm $spacing-xxl;
      box-sizing: border-box;
      width: 100%;
      margin: 0;
      padding: $spacing-md $spacing-md;
      background: $color-white;
      color: rgba($color-text, 0.55);

      @media (max-width: $breakpoint-sp) {
        flex-direction: column;
        align-items: flex-start;
        padding: $spacing-sm $spacing-sm;
      }

      .footer__legal-link {
        font-family: $noto-sans-jp;
        font-size: 12px;
        font-weight: $fw-regular;
        color: rgba($color-text, 0.55);
        text-decoration: none;

        &:hover {
          opacity: 0.75;
        }
      }

      .footer__legal-copy {
        margin: 0;
        font-family: $noto-sans-jp;
        font-size: 12px;
        font-weight: $fw-regular;
        line-height: 1.5;
        color: rgba($color-text, 0.55);
        text-align: right;

        @media (max-width: $breakpoint-sp) {
          text-align: left;
        }
      }
    }
  }
</style>
