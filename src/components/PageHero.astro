---
import { withBase } from "../utils/withBase";

interface Props {
  imageSrc: string;
  imageAlt: string;
  title: string;
  overlay?: boolean;
}

const { imageSrc, imageAlt, title, overlay = true } = Astro.props;
---

<section class="page-hero">
  <div class="page-hero__image-wrap">
    <img
      class="page-hero__image"
      src={withBase(imageSrc)}
      alt={imageAlt}
      width="1200"
      height="480"
    />
    {overlay && <div class="page-hero__overlay" aria-hidden="true" />}
  </div>
  <div class="page-hero__inner">
    <h1 class="page-hero__title">{title}</h1>
  </div>
</section>

<style lang="scss">
  @use "../styles/variables" as *;

  .page-hero {
    position: relative;
    margin-top: -100px;

    @media (max-width: $breakpoint-sp) {
      margin-top: -60px;
    }

    .page-hero__image-wrap {
      position: relative;
      width: 100%;
      max-height: 360px;
      overflow: hidden;

      @media (max-width: $breakpoint-sp) {
        max-height: 280px;
      }
    }

    .page-hero__image {
      width: 100%;
      height: 420px;
      object-fit: cover;
      display: block;

      @media (max-width: $breakpoint-sp) {
        height: 280px;
      }
    }

    .page-hero__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        180deg,
        rgba($color-primary, 0.55) 0%,
        rgba($color-primary, 0.35) 100%
      );
    }

    .page-hero__inner {
      position: absolute;
      top: 60%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 100%;
      max-width: $content-max-width;
      padding: 0;
      z-index: 2;
    }

    .page-hero__title {
      margin: 0;
      font-family: $noto-sans-jp;
      font-size: 52px;
      font-weight: $fw-bold;
      color: $color-white;
      line-height: 1.4;
      position: relative;
      padding-left: $spacing-lg;

      @media (max-width: $breakpoint-sp) {
        font-size: 32px;
      }

      &::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 4px;
        height: 100%;
        background: #fff;

        @media (max-width: $breakpoint-sp) {
          width: 3px;
        }
      }
    }
  }
</style>
